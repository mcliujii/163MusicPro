<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:layout_marginTop="2dp"
    android:layout_marginBottom="2dp">

    <!-- Song name row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Download status icon indicator -->
        <View
            android:id="@+id/status_indicator"
            android:layout_width="3dp"
            android:layout_height="24dp"
            android:background="#03DAC6"
            android:layout_marginEnd="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_download_song_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_download_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#B3FFFFFF"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Percentage text -->
        <TextView
            android:id="@+id/tv_download_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BB86FC"
            android:textSize="12sp"
            android:textStyle="bold"
            android:minWidth="36dp"
            android:gravity="end" />
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/download_progress_bar"
        android:indeterminate="false" />

    <!-- Info row: size, speed, status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_download_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:text="0B / 0B" />

        <TextView
            android:id="@+id/tv_download_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#03DAC6"
            android:textSize="10sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_download_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
