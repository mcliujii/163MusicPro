<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="4dp">

    <!-- Top left playlist indicator (hidden by default) -->
    <ImageView
        android:id="@+id/btn_playlist_indicator"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:padding="4dp"
        android:src="@drawable/ic_queue_music"
        android:alpha="0.87"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- Top right more button -->
    <ImageView
        android:id="@+id/btn_more"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:padding="4dp"
        android:src="@drawable/ic_more_vert"
        android:alpha="0.87"
        android:clickable="true"
        android:focusable="true" />

    <!-- Center content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <!-- Song name with marquee -->
        <TextView
            android:id="@+id/tv_song_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="@string/no_song"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Artist name -->
        <TextView
            android:id="@+id/tv_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:gravity="center"
            android:singleLine="true"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <!-- SeekBar with time labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_secondary"
                android:textSize="9sp" />

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/colorPrimary"
                android:thumbTint="@color/colorPrimary" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_secondary"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Playback controls row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_prev"
                android:layout_width="50dp"
                android:layout_height="38dp"
                android:padding="9dp"
                android:src="@drawable/ic_skip_previous"
                android:alpha="0.87"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/btn_play"
                android:layout_width="50dp"
                android:layout_height="38dp"
                android:padding="7dp"
                android:src="@drawable/ic_play_arrow"
                android:alpha="1.0"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/btn_next"
                android:layout_width="50dp"
                android:layout_height="38dp"
                android:padding="9dp"
                android:src="@drawable/ic_skip_next"
                android:alpha="0.87"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Volume / function controls row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_vol_down"
                android:layout_width="50dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_volume_down"
                android:alpha="0.6"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/btn_favorite"
                android:layout_width="50dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_more_horiz"
                android:clickable="true"
                android:focusable="true" />

            <ImageView
                android:id="@+id/btn_vol_up"
                android:layout_width="50dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_volume_up"
                android:alpha="0.6"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
